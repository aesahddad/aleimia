# Aleinia Platform Configuration
PORT=3000

# MongoDB Connection String
MONGO_URI=mongodb://127.0.0.1:27017/aleinia_dev

# Environment
NODE_ENV=development

# JWT Secrets
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Frontend URL (for OAuth callbacks)
FRONTEND_URL=http://localhost:3001

# Social Auth - Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Social Auth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Social Auth - LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Social Auth - Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Social Auth - TikTok
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Social Auth - Snapchat
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
